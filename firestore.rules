rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Admin authorization helper
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Roadmaps: public read published, admin CRUD
    match /roadmaps/{roadmapId} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isAdmin() && resource.data.status != 'published';
    }

    // Projects: public read published, admin CRUD
    match /projects/{projectId} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isAdmin() && resource.data.status != 'published';
    }

    // Resources: public read published, admin CRUD
    match /resources/{resourceId} {
      allow read: if resource.data.status == 'published'
                  || (request.auth != null && isAdmin());
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // DSA Problems: public read published, admin CRUD
    match /dsa-problems/{problemId} {
      allow read: if resource.data.status == 'published'
                  || (request.auth != null && isAdmin());
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Analytics: anyone can increment views, admins can read all
    match /analytics/{docId} {
      allow read: if isAdmin();
      allow create, update: if true;
      allow delete: if isAdmin();
    }

    // Users: each user can read/write their own document
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Subscribers: anyone can create (newsletter signup)
    match /subscribers/{email} {
      allow create, update: if true;
      allow read, delete: if isAdmin();
    }

    // Admins collection: only readable by the admin themselves
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }
  }
}
